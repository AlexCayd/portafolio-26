# Enruta todas las peticiones al front-controller (index.php) poblando PATH_INFO.
# Requiere que el DocumentRoot apunte a la carpeta /public.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Sirve archivos y carpetas reales directamente (assets de /build, etc.)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # El resto va al front-controller como PATH_INFO
    RewriteRule ^(.*)$ index.php/$1 [L,QSA]
</IfModule>
